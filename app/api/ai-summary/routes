/**
 * ============================================================
 * COMPUTE LAYER: SERVERLESS FUNCTION + FLUID COMPUTE
 * ============================================================
 * This endpoint demonstrates the AI workload pattern that
 * makes Fluid Compute transformative.
 *
 * THE PROBLEM WITH TRADITIONAL SERVERLESS FOR AI:
 *  - You call an LLM (OpenAI/Anthropic)
 *  - Your function WAITS 10-30 seconds for the response
 *  - Traditional serverless: you pay for ALL 30 seconds
 *  - But your CPU is doing NOTHING during those 30 seconds
 *  - 95% of the cost is wasted on waiting
 *
 * FLUID COMPUTE SOLUTION:
 *  - Multiple requests can share one compute instance
 *  - While request A waits for OpenAI, request B runs on same instance
 *  - You pay only for ACTIVE CPU time (milliseconds), not wait time
 *  - Result: AI workloads cost up to 85% less on Vercel
 *
 * STREAMING:
 *  - Instead of waiting for the full LLM response, we stream tokens
 *  - First token appears in ~500ms instead of user waiting 10-30s
 *  - This is enabled by the Vercel AI SDK's streamText()
 *
 * VERCEL AI SDK:
 *  - Handles streaming protocol (text/event-stream)
 *  - Works with 20+ LLM providers via unified API
 *  - toDataStreamResponse() formats output for use with useChat() hook
 * ============================================================
 */

import { NextRequest, NextResponse } from "next/server";

